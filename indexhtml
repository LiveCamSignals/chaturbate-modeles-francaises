  <script>
    (function () {
      'use strict';

      // Chaturbate API endpoints (public / affiliate)
      const API_URL = 'https://chaturbate.com/api/public/affiliates/onlinerooms/?wm=T2CSW&client_ip=request_ip&limit=500&offset=0&format=json';
      const TAGGED_API_URLS = [API_URL + '&tag=pinay', API_URL + '&tag=filipina'];

      let allRooms = [];
      let filtered = [];
      let currentPage = 1;
      let sortCol = 'num_users';
      let sortDir = 'desc';
      let lastFetched = null;

      function el(id) { return document.getElementById(id); }

      function escHtml(s) {
        return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }

      function normalizeTags(tags) {
        if (Array.isArray(tags)) return tags.map(t => String(t || '').trim()).filter(Boolean);
        if (typeof tags === 'string') return tags.split(/[\s,]+/).map(t => t.trim()).filter(Boolean);
        return [];
      }

      function tagMatchesAllowed(tags) {
        return normalizeTags(tags).some(t => {
          t = String(t || '').toLowerCase();
          return t === 'pinay' || t === 'filipina';
        });
      }

      function allowedMatch(r) {
        return r._matchedTag || tagMatchesAllowed(r.tags);
      }

      function revshareRoomUrl(username) {
        return 'https://chaturbate.com/in/?tour=bbrB&campaign=T2CSW&track=default&tag=pinay&gender=f&room=' + encodeURIComponent(username || '');
      }

      function normalize(r) {
        const username = r.username || r.display_name || 'filipina-live';
        let matchingTags = normalizeTags(r.tags).filter(t => {
          t = String(t || '').toLowerCase();
          return t === 'pinay' || t === 'filipina';
        });
        if (!matchingTags.length && r._matchedTag) matchingTags = [r._matchedTag];
        if (!matchingTags.length) matchingTags = ['pinay', 'Filipina'];

        return {
          username: username,
          display_name: r.display_name || username,
          source: 'Chaturbate',
          num_users: typeof r.num_users === 'number' ? r.num_users : (r.viewers || r.num_users || 'Live'),
          tags: matchingTags,
          image_url: r.image_url || r.thumb || r.snapshot_url || '',
          url: revshareRoomUrl(username)
        };
      }

      function setLoading() {
        el('rooms-body').innerHTML = '<tr id="loading-row"><td colspan="6"><span class="spinner"></span>Fetching live rooms…</td></tr>';
        el('pagination').innerHTML = '';
        el('status-text').textContent = 'Loading…';
        el('status-showing').textContent = '—';
      }

      function fetchAllRooms(url, acc, matchedTag) {
        acc = acc || [];
        return fetch(url, { mode: 'cors' })
          .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(data => {
            let results = Array.isArray(data) ? data : (data.results || data.rooms || data.data || []);
            results = results.map(room => {
              if (matchedTag && !room._matchedTag) room._matchedTag = matchedTag;
              return room;
            });
            acc = acc.concat(results);
            if (data && data.next && acc.length < 10000) return fetchAllRooms(data.next, acc, matchedTag);
            return acc;
          });
      }

      function dedupeRooms(rooms) {
        const seen = {};
        return rooms.filter(room => {
          const key = String(room.username || room.display_name || room.chat_room_url || room.url || '').toLowerCase();
          if (!key || seen[key]) return false;
          seen[key] = true;
          return true;
        });
      }

      function fetchTaggedRooms() {
        return Promise.all([
          fetchAllRooms(TAGGED_API_URLS[0], [], 'pinay').catch(() => []),
          fetchAllRooms(TAGGED_API_URLS[1], [], 'Filipina').catch(() => []),
          fetchAllRooms(API_URL, [], '').catch(() => [])
        ]).then(sets => {
          return dedupeRooms([].concat(sets[0], sets[1], sets[2]));
        });
      }

      function applyFilters() {
        const q = (el('search-input').value || '').toLowerCase().trim();
        filtered = allRooms.filter(r => {
          const text = [r.username, r.display_name, r.source, (r.tags || []).join(' ')].join(' ').toLowerCase();
          return !q || text.indexOf(q) !== -1;
        });
        sortAndRender();
      }

      function sortAndRender() {
        const col = sortCol;
        const dir = sortDir;
        filtered.sort((a, b) => {
          let av = a[col];
          let bv = b[col];
          const an = typeof av === 'number' ? av : parseInt(String(av).replace(/[^0-9]/g, ''), 10);
          const bn = typeof bv === 'number' ? bv : parseInt(String(bv).replace(/[^0-9]/g, ''), 10);
          if (!isNaN(an) && !isNaN(bn)) return dir === 'asc' ? an - bn : bn - an;
          av = String(av || '').toLowerCase();
          bv = String(bv || '').toLowerCase();
          return av < bv ? (dir === 'asc' ? -1 : 1) : av > bv ? (dir === 'asc' ? 1 : -1) : 0;
        });
        currentPage = 1;
        render();
      }

      function render() {
        const perPage = parseInt(el('per-page-select').value, 10) || 50;
        const total = filtered.length;
        const pages = Math.ceil(total / perPage) || 1;
        if (currentPage > pages) currentPage = pages;
        const start = (currentPage - 1) * perPage;
        const end = Math.min(start + perPage, total);
        const slice = filtered.slice(start, end);

        el('status-text').textContent = total.toLocaleString() + ' rows';
        el('seo-count').textContent = total.toLocaleString();
        el('status-showing').textContent = total ? 'showing ' + (start + 1) + '–' + end : 'showing 0';
        el('status-updated').textContent = lastFetched ? 'updated ' + lastFetched.toLocaleTimeString() : '';
        el('total-count').textContent = total.toLocaleString();

        if (!slice.length) {
          el('rooms-body').innerHTML = '<tr id="empty-row"><td colspan="6">No pinay or Filipina rows match your filters.</td></tr>';
          el('pagination').innerHTML = '';
          return;
        }

        el('rooms-body').innerHTML = slice.map(r => {
          const img = r.image_url ? '<img class="avatar" src="' + escHtml(r.image_url) + '" alt="" loading="lazy"/>' : '<span class="avatar"></span>';
          const viewers = typeof r.num_users === 'number' ? r.num_users.toLocaleString() : escHtml(r.num_users || 'Live');
          const tags = (r.tags || ['pinay', 'Filipina']).map(tag => '<span class="tag" onclick="filterTag(\'' + escHtml(tag) + '\')">' + escHtml(tag) + '</span>').join('');
          return '<tr>'
            + '<td class="col-user"><a href="' + escHtml(r.url) + '" target="_blank" rel="nofollow sponsored noopener">' + img + escHtml(r.display_name || r.username) + '</a></td>'
            + '<td><span class="badge-live">LIVE</span></td>'
            + '<td class="col-viewers num"><span class="viewers-val">' + viewers + '</span></td>'
            + '<td class="col-source"><span class="source-val">' + escHtml(r.source || 'Source') + '</span></td>'
            + '<td class="col-tags"><div class="tags-cell">' + tags + '</div></td>'
            + '<td><a href="' + escHtml(r.url) + '" target="_blank" rel="nofollow sponsored noopener">Open</a></td>'
            + '</tr>';
        }).join('');

        renderPagination(total, pages);
      }

      function renderPagination(total, pages) {
        const pg = el('pagination');
        if (pages <= 1) { pg.innerHTML = ''; return; }
        let html = '<button ' + (currentPage <= 1 ? 'disabled' : '') + ' onclick="goPage(' + (currentPage - 1) + ')">‹ Prev</button>';
        const show = {};
        show[1] = true; show[pages] = true;
        for (let i = Math.max(1, currentPage - 2); i <= Math.min(pages, currentPage + 2); i++) show[i] = true;
        let prev = 0;
        Object.keys(show).map(Number).sort((a, b) => a - b).forEach(p => {
          if (prev && p - prev > 1) html += '<button disabled>…</button>';
          html += '<button class="' + (p === currentPage ? 'active' : '') + '" onclick="goPage(' + p + ')">' + p + '</button>';
          prev = p;
        });
        html += '<button ' + (currentPage >= pages ? 'disabled' : '') + ' onclick="goPage(' + (currentPage + 1) + ')">Next ›</button>';
        html += '<span class="page-info">page ' + currentPage + ' of ' + pages + ' &nbsp;·&nbsp; ' + total.toLocaleString() + ' results</span>';
        pg.innerHTML = html;
      }

      window.fetchRooms = function () {
        setLoading();
        const btn = el('refresh-btn');
        btn.textContent = 'Loading…';
        btn.disabled = true;
        fetchTaggedRooms()
          .then(results => {
            const live = results.filter(allowedMatch).map(normalize);
            allRooms = live;
            lastFetched = new Date();
            applyFilters();
          })
          .catch(() => {
            allRooms = [];
            lastFetched = new Date();
            applyFilters();
          })
          .finally(() => {
            btn.textContent = '↻ Refresh';
            btn.disabled = false;
          });
      };

      window.goPage = function (p) { currentPage = p; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); };
      window.sortBy = function (th) {
        const col = th.getAttribute('data-sort');
        if (!col) return;
        if (sortCol === col) sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        else { sortCol = col; sortDir = col === 'num_users' ? 'desc' : 'asc'; }
        document.querySelectorAll('#rooms-table thead th').forEach(h => {
          h.classList.remove('sort-asc', 'sort-desc');
          if (h.getAttribute('data-sort') === sortCol) h.classList.add(sortDir === 'asc' ? 'sort-asc' : 'sort-desc');
        });
        sortAndRender();
      };
      window.filterTag = function (tag) { el('search-input').value = tag; applyFilters(); };

      el('search-input').addEventListener('input', applyFilters);
      el('per-page-select').addEventListener('change', function () { currentPage = 1; render(); });
      document.querySelectorAll('#rooms-table thead th').forEach(h => {
        if (h.getAttribute('data-sort') === sortCol) h.classList.add('sort-desc');
      });

      // initial fetch
      window.fetchRooms();
      setInterval(window.fetchRooms, 5 * 60 * 1000);
    })();
  </script>
</body>
</html>
